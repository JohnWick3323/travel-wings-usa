# Shopify Admin API
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_API_VERSION=2025-04

# SFTP (Print Royal warehouse)
SFTP_HOST=ftp.example.com
SFTP_PORT=22
SFTP_USERNAME=user
SFTP_PASSWORD=pass
SFTP_INCOMING_DIR=/from_print
SFTP_PROCESSED_DIR=/processed_shopify_fullfilment
SFTP_ERROR_DIR=/error_fullfilment

# Worker settings
POD_LOCATION_NAME=Print Royal GmbH
POLL_INTERVAL_MINUTES=60
