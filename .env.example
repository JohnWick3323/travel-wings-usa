# WordPress GraphQL endpoint (required)
PUBLIC_WP_URL=https://backend.travelwingsusa.com/wp-json/wp/v2

# GraphQL URL is auto-derived from PUBLIC_WP_URL
# https://backend.travelwingsusa.com/graphql

# Resend email API key (required for contact forms)
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
