---
import Layout from '~/layouts/Layout.astro';
import { ArticleHeader } from '~/blocks/blog-article/article-header';
import { ArticleContentAndSidebar } from '~/blocks/blog-article/article-content-and-sidebar';
import { RelatedArticles } from '~/blocks/blog-article/related-articles';
import { getBlogPosts, getBlogPostBySlug } from '~/lib/wordpress';
import { blogPostingSchema, breadcrumbSchema } from '~/lib/structured-data';
import styles from '~/styles/pages/blog-article.module.css';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const allPosts = await getBlogPosts();
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 3);

const articleSchema = blogPostingSchema(post);
const breadcrumb = breadcrumbSchema([
  { name: 'Home', url: 'https://travelwingsusa.com' },
  { name: 'Blog', url: 'https://travelwingsusa.com/blog' },
  { name: post.title, url: `https://travelwingsusa.com/blog/${post.id}` },
]);
---

<Layout
  title={`${post.title} - Travel Wings USA`}
  description={post.excerpt}
  ogImage={post.image || undefined}
  ogType="article"
  canonical={`https://travelwingsusa.com/blog/${post.id}`}
  extraSchemas={[articleSchema, breadcrumb]}
>
  <main class={styles.page}>
    <ArticleHeader post={post} client:load />
    <ArticleContentAndSidebar post={post} client:load />
    <RelatedArticles posts={related} client:load />
  </main>
</Layout>
