---
import Layout from '~/layouts/Layout.astro';
import styles from '~/styles/pages/legal-page.module.css';
---

<Layout
  title="Terms of Service - Travel Wings USA"
  description="Terms of Service for Travel Wings USA. Read our terms and conditions for using our travel services."
  canonical="https://travelwingsusa.com/terms-of-service"
>
  <main class={styles.page} id="main-content">
    <div class={styles.container}>
      <h1 class={styles.title}>Terms of Service</h1>
      <p class={styles.updated}>Last Updated: April 2025</p>
      <section class={styles.section}>
        <h2>1. Acceptance of Terms</h2>
        <p>By accessing and using the Travel Wings USA website, you agree to be bound by these Terms of Service.</p>
      </section>
      <section class={styles.section}>
        <h2>2. Services</h2>
        <p>Travel Wings USA provides travel consultation, package planning, and booking assistance for Umrah, Hajj, international flights, and vacation tours.</p>
      </section>
      <section class={styles.section}>
        <h2>3. Quote Requests</h2>
        <p>Submitting a quote request does not constitute a booking. A booking is confirmed only after mutual agreement and payment.</p>
      </section>
      <section class={styles.section}>
        <h2>4. Cancellations and Refunds</h2>
        <p>Cancellation and refund policies vary by package and are communicated at the time of booking.</p>
      </section>
      <section class={styles.section}>
        <h2>5. Contact Us</h2>
        <p>Email: <a href="mailto:info@travelwingsusa.com">info@travelwingsusa.com</a> | Phone: +1 410-298-4500</p>
      </section>
    </div>
  </main>
</Layout>
