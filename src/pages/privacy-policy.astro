---
import Layout from '~/layouts/Layout.astro';
import styles from '~/styles/pages/legal-page.module.css';
---

<Layout
  title="Privacy Policy - Travel Wings USA"
  description="Privacy Policy for Travel Wings USA. Learn how we collect, use, and protect your personal information."
  canonical="https://travelwingsusa.com/privacy-policy"
>
  <main class={styles.page}>
    <div class={styles.container}>
      <h1 class={styles.title}>Privacy Policy</h1>
      <p class={styles.updated}>Last Updated: April 2025</p>
      <section class={styles.section}>
        <h2>1. Information We Collect</h2>
        <p>When you use our website or request a quote, we may collect:</p>
        <ul>
          <li>Name, email address, and phone number</li>
          <li>Travel preferences and destination interests</li>
          <li>Information you provide through our contact and inquiry forms</li>
          <li>Technical data such as IP address, browser type, and device information</li>
        </ul>
      </section>
      <section class={styles.section}>
        <h2>2. How We Use Your Information</h2>
        <p>We use your information to respond to travel inquiries, provide customized packages, send newsletters (with consent), and improve our services.</p>
      </section>
      <section class={styles.section}>
        <h2>3. Information Sharing</h2>
        <p>We do not sell your personal information. We may share with trusted travel partners solely to fulfill your travel arrangements.</p>
      </section>
      <section class={styles.section}>
        <h2>4. Contact Us</h2>
        <p>Email: <a href="mailto:info@travelwingsusa.com">info@travelwingsusa.com</a> | Phone: +1 410-298-4500</p>
      </section>
    </div>
  </main>
</Layout>
