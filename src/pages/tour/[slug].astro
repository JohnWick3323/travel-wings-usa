---
import Layout from '~/layouts/Layout.astro';
import { TourPageHero } from '~/blocks/tour-details/tour-page-hero';
import { TourImageGallery } from '~/blocks/tour-details/tour-image-gallery';
import { TourDetailsTabs } from '~/blocks/tour-details/tour-details-tabs';
import { StickyQuoteRequestForm } from '~/blocks/tour-details/sticky-quote-request-form';
import { RelatedTours } from '~/blocks/tour-details/related-tours';
import { getTours, getTourBySlug, getRelatedTours } from '~/lib/wordpress';
import { tourSchema, breadcrumbSchema } from '~/lib/structured-data';
import styles from '~/styles/pages/tour-details.module.css';

export async function getStaticPaths() {
  const tours = await getTours();
  return tours.map((tour) => ({ params: { slug: tour.id } }));
}

const { slug } = Astro.params;
const tour = await getTourBySlug(slug!);

if (!tour) {
  return Astro.redirect('/destinations');
}

const allTours = await getTours();
const related = getRelatedTours(allTours, tour.id);

const schemas = tourSchema(tour);
const breadcrumb = breadcrumbSchema([
  { name: 'Home', url: 'https://travelwingsusa.com' },
  { name: 'Destinations', url: 'https://travelwingsusa.com/destinations' },
  { name: tour.title, url: `https://travelwingsusa.com/tour/${tour.id}` },
]);
---

<Layout
  title={`${tour.title} - ${tour.duration} | Travel Wings USA`}
  description={tour.description.slice(0, 160)}
  ogImage={tour.image}
  canonical={`https://travelwingsusa.com/tour/${tour.id}`}
  extraSchemas={[...schemas, breadcrumb]}
>
  <main class={styles.page}>
    <TourPageHero tour={tour} client:load />
    <div class={styles.content}>
      <div class={styles.main}>
        <TourImageGallery tour={tour} client:load />
        <TourDetailsTabs tour={tour} client:load />
        <RelatedTours tours={related} client:load />
      </div>
      <StickyQuoteRequestForm tour={tour} client:load />
    </div>
  </main>
</Layout>
