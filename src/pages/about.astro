---
import Layout from '~/layouts/Layout.astro';
import { AboutPageHero } from '~/blocks/about-us/about-page-hero';
import { OurStorySection } from '~/blocks/about-us/our-story-section';
import { MissionAndValues } from '~/blocks/about-us/mission-and-values';
import { AboutCtaBanner } from '~/blocks/about-us/about-cta-banner';
import styles from '~/styles/pages/about-us.module.css';
---

<Layout
  title="About Us - Travel Wings USA"
  description="Learn about Travel Wings USA, a Maryland-based travel agency specializing in Umrah, Hajj, and international travel packages."
  canonical="https://travelwingsusa.com/about"
>
  <main class={styles.page}>
    <AboutPageHero client:load />
    <OurStorySection client:load />
    <MissionAndValues client:load />
    <AboutCtaBanner client:load />
  </main>
</Layout>
