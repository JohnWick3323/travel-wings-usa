---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Page Not Found - Travel Wings USA" noindex={true}>
  <main style="text-align:center; padding: 120px 24px;">
    <h1 style="font-size: 4rem; color: var(--color-primary);">404</h1>
    <p style="font-size: 1.25rem; margin: 16px 0 32px;">Page not found.</p>
    <a href="/" style="background: var(--color-primary); color: white; padding: 12px 32px; border-radius: var(--radius-pill); font-weight: 600;">
      Go Home
    </a>
  </main>
</Layout>
